# devagi environment example
# Copy to `.env` and adjust. `.env` is gitignored.
# 拷贝为 `.env` 后按需修改；`.env` 已在 gitignore 中。

# --- Path overrides (default to ./data, ./logs, ./checkpoints) ---
# DEVAGI_DATA_DIR=./data
# DEVAGI_LOGS_DIR=./logs
# DEVAGI_CKPT_DIR=./checkpoints

# --- Default preset (used when --preset not passed) ---
DEVAGI_PRESET=local_smoke

# --- PyTorch allocator fragmentation mitigation ---
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- rsync remote target (Phase 2/3) ---
# DEVAGI_REMOTE_TARGET=user@host:/path/to/karbon-mirror
# DEVAGI_MIRROR_SOURCE=user@host:/path/to/karbon-mirror

# --- Optional: Weights & Biases ---
# WANDB_API_KEY=
# WANDB_PROJECT=devagi
# WANDB_MODE=offline
